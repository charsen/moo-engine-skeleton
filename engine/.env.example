# ──────────────────────────────────────────────────────────────────────
# 应用
# APP_KEY 由 `php artisan key:generate` 生成；
# 8088：本机 8000 被其它项目占用（见 docs 第 1 章）。
# ──────────────────────────────────────────────────────────────────────
APP_NAME=moo-engine-skeleton
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8088

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

BCRYPT_ROUNDS=12

# scaffold 接口调试器的代理会回调本服务器，单线程 serve 会死锁（踩坑 #4）：
# PHP_CLI_SERVER_WORKERS=4 php artisan serve --host=127.0.0.1 --port=8088 --no-reload
PHP_CLI_SERVER_WORKERS=4

# ──────────────────────────────────────────────────────────────────────
# 日志
# ──────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────────
# 数据库（教程用 MariaDB，兼容 mysql 驱动，见 docs 第 1 章）
# 建库：CREATE DATABASE moo_skeleton CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# ──────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=moo_skeleton
DB_USERNAME=root
DB_PASSWORD=7777          # 教程示例密码，换成你自己的

# ──────────────────────────────────────────────────────────────────────
# 缓存 / 会话 / 队列
# JWT 黑名单、雪花 ID 都走 cache；生产多 worker 时必须换 redis
# （CACHE_STORE=redis，并放开下面的 REDIS_*）。
# ──────────────────────────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
# 教程用 sync：登录记录/操作日志即时落库可见；生产换 redis + queue worker
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# 操作日志（写入 system_operation_logs，开发期开着便于在后台「操作日志」模块看到效果）
OPERATION_LOG=true

# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────────────
# JWT（php artisan jwt:secret 生成）
# ttl / 黑名单宽限期等默认值已固化在 config/jwt.php，env 只需密钥。
# ──────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ──────────────────────────────────────────────────────────────────────
# moo-scaffold（php artisan moo:init "你的名字" 写入；生成代码的作者署名）
# ──────────────────────────────────────────────────────────────────────
SCAFFOLD_AUTHOR=

# 慢 SQL 监听（moo-monitor-laravel 提供，随 scaffold 3.9.0 自动带入）：超过阈值的查询
# 落盘 storage/moo-monitor/sql-slows，/scaffold 的 S-Cloud 页可看缓冲；纯开关零代码
MOO_MONITOR_SQL_SLOW_ENABLED=true
MOO_MONITOR_SQL_SLOW_THRESHOLD_MS=100

VITE_APP_NAME="${APP_NAME}"

