# ──────────────────────────────────────────────────────────────────────
# 应用
# APP_KEY 由 `php artisan key:generate` 生成；
# 8088：本机 8000 被其它项目占用（见 docs 第 1 章）。
# ──────────────────────────────────────────────────────────────────────
APP_NAME=moo-engine-skeleton
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8088

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

BCRYPT_ROUNDS=12

# scaffold 接口调试器的代理会回调本服务器，单线程 serve 会死锁（踩坑 #4）：
# PHP_CLI_SERVER_WORKERS=4 php artisan serve --host=127.0.0.1 --port=8088 --no-reload
PHP_CLI_SERVER_WORKERS=4

# ──────────────────────────────────────────────────────────────────────
# 日志
# ──────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────────
# 数据库：默认 SQLite，克隆后无需外部服务即可安装与测试。
# 正式项目切 MySQL/MariaDB 时取消下方示例注释，并为每个项目使用独立库名与凭据。
# ──────────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=your_project
# DB_USERNAME=root
# DB_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# 缓存 / 会话 / 队列
# JWT 黑名单、雪花 ID 都走 cache；生产多 worker 时必须换 redis
# （CACHE_STORE=redis，并放开下面的 REDIS_*）。
# ──────────────────────────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
# 教程用 sync：登录记录/操作日志即时落库可见；生产换 redis + queue worker
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# 操作日志（写入 system_operation_logs，开发期开着便于在后台「操作日志」模块看到效果）
OPERATION_LOG=true

# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────────────
# JWT（php artisan jwt:secret 生成）
# ttl / 黑名单宽限期等默认值已固化在 config/jwt.php，env 只需密钥。
# ──────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ──────────────────────────────────────────────────────────────────────
# 雪花主键：start_time 一旦上线生成过 ID 就不可修改；多机部署时 worker 组合必须唯一。
# ──────────────────────────────────────────────────────────────────────
SNOW_FLAKE_DATA_CENTER_ID=1
SNOW_FLAKE_WORKER_ID=1
SNOW_FLAKE_START_TIME=2026-01-01

# ──────────────────────────────────────────────────────────────────────
# moo-scaffold（php artisan moo:init "你的名字" 写入；生成代码的作者署名）
# ──────────────────────────────────────────────────────────────────────
SCAFFOLD_AUTHOR=

# 慢 SQL 监听（moo-monitor-laravel 提供，随 scaffold 3.9.0 自动带入）：超过阈值的查询
# 落盘 storage/moo-monitor/sql-slows，/scaffold 的 S-Cloud 页可看缓冲；纯开关零代码
MOO_MONITOR_SQL_SLOW_ENABLED=true
MOO_MONITOR_SQL_SLOW_THRESHOLD_MS=100
MOO_MONITOR_CLOUD_ENABLED=false
MOO_MONITOR_CLOUD_TOKEN=

VITE_APP_NAME="${APP_NAME}"
